{
  "schemaVersion": 1,
  "id": "tweakmousesensitivity",
  "version": "${version}",
  "name": "tweakmousesensitivity",
  "description": "make a 20000 dpi or even higher mouse works fine in mc",
  "authors": ["prohect@foxmail.com!"],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/prohect/tweakmousesensitivity"
  },
  "license": "CC0-1.0",
  "icon": "assets/tweak-mouse-sensitivity/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.github.prohect.TweakMouseSensitivity"],
    "client": ["com.github.prohect.TweakMouseSensitivityClient"]
  },
  "mixins": [
    "tweak-mouse-sensitivity.mixins.json",
    {
      "config": "tweak-mouse-sensitivity.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "tweak-mouse-sensitivity.accesswidener",
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=26.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
